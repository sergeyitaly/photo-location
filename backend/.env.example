# Photo Geolocation System Configuration

# App Settings
DEBUG=True
HOST=0.0.0.0
PORT=8000
APP_NAME="Photo Geolocation System"

# ML Model Settings
MODEL_DEVICE=cpu  # cpu or cuda
USE_ON_DEVICE_MODEL=True
USE_STREETCLIP=True
# FastAPI app `app.config` (Hugging Face id for CLIP zero-shot ensemble + cue panels)
GLOBE_CLIP_MODEL_ID=openai/clip-vit-base-patch32
# When true and torch+transformers are installed, ensemble uses CLIP zero-shot country + landmark prompts (not histogram mock)
ENSEMBLE_USE_CLIP_ZERO_SHOT=True
# How many top softmax labels to return in ml_image_recognition
ML_RECOGNITION_TOP_N=15
# On uvicorn startup, load CLIP + (if enabled) GeoCLIP + StreetCLIP so the first /predict is not blocked by downloads/load
PRELOAD_TORCH_MODELS_AT_STARTUP=True
# CLIP banks: gas/power grid/solar/wind + visual economic-activity proxies (uses GLOBE_CLIP_MODEL_ID)
USE_INFRASTRUCTURE_ENERGY_CLIP=True
INFRASTRUCTURE_ENERGY_CLIP_TOP_N=8
# GeoCLIP (pip geoclip) + StreetCLIP — fusion weights should sum ~1 for interpretability
USE_GEOCLIP=True
USE_STREETCLIP=True
STREETCLIP_MODEL_ID=geolocal/StreetCLIP
STREETCLIP_GAZETTEER_CHUNK_SIZE=48
# Gazetteer JSON: optional explicit path. If unset, server uses autoload output below when the file exists.
# STREETCLIP_GAZETTEER_PATH=app/data/generated/streetclip_gazetteer_cities1000_world.json
# Startup: download GeoNames + build worldwide gazetteer (StreetCLIP enabled). Poll GET /config field gazetteer_autoload.
STREETCLIP_GAZETTEER_AUTOLOAD_AT_STARTUP=True
# cities1000 | cities5000 | cities15000 → app/data/generated/streetclip_gazetteer_{dump}_world.json
STREETCLIP_GAZETTEER_AUTOLOAD_DUMP=cities1000
STREETCLIP_GAZETTEER_AUTOLOAD_SKIP_IF_EXISTS=True
# Restrict labels to a box around GeoCLIP rank-1 (recommended with large files).
STREETCLIP_GAZETTEER_GEO_FILTER=True
STREETCLIP_GAZETTEER_BBOX_LAT_DEG=10
STREETCLIP_GAZETTEER_BBOX_LON_DEG=14
STREETCLIP_GAZETTEER_MAX_LABELS=12000
STREETCLIP_GAZETTEER_MIN_POPULATION=0
# Admin API: POST /gazetteer/build (optional). Disable on untrusted public hosts.
GAZETTEER_BUILD_ENABLED=True
# Optional override for generated JSON directory (default: app/data/generated)
# GAZETTEER_DATA_DIR=
#
# Optional ANN retrieval: offline Faiss index of CLIP image embeddings + lat/lon table (pip install faiss-cpu).
# Build with the same CLIP model as GLOBE_CLIP_MODEL_ID; vectors must be L2-normalized (IndexFlatIP).
# FAISS_GEOTAG_INDEX_PATH=/path/to/index.faiss
# FAISS_GEOTAG_COORDS_NPY_PATH=/path/to/coords_float32_Nx2.npy
FUSION_WEIGHT_GEOCLIP=0.45
FUSION_WEIGHT_STREETCLIP=0.35
FUSION_WEIGHT_CLIP_ZS=0.20
# Accuracy: CLIP country allowlist before StreetCLIP; dynamic GeoCLIP down-weight when StreetCLIP is confident
STREETCLIP_COUNTRY_FILTER_ENABLED=True
STREETCLIP_COUNTRY_FILTER_MAX_COUNTRIES=3
STREETCLIP_CONFIDENT_MARGIN_THRESHOLD=0.10
GEOCLIP_DOWNWEIGHT_WHEN_STREETCLIP_CONFIDENT=0.55
# Fast mode: mini grid only when GeoCLIP / CLIP country signal is weak
FAST_MODE_CONFIDENCE_GATED_GRID=True
FAST_GRID_GEOCLIP_MAX_CONFIDENCE=0.14
# Feature analysis: CLIP landmarks/architecture + optional Tesseract OCR (pip install pytesseract)
FEATURE_ANALYSIS_CLIP_LANDMARKS=True
FEATURE_ANALYSIS_CLIP_ARCHITECTURE=True
FEATURE_ANALYSIS_OCR_ENABLED=True
# Finer lat/lon bins when merging sources (3 ≈ ~100 m latitude; 2 blurs ~1 km). More GeoCLIP ranks compete in fusion.
FUSION_DEDUPE_DECIMALS=3
GEOCLIP_MERGE_MAX_RANKS=16
# Comma-separated Hugging Face repo IDs for CLIP city-grid inference (each checkpoint loads separately into RAM).
# Fusion: VISION_FUSION_STRATEGY=max_confidence (default) picks the strongest model top-1; mean_probability averages softmax vectors then ranks (good with 2+ repos).
# Optional extra StreetCLIP-family checkpoints (large downloads — test before prod): solary/StreetCLIP-finetuned-Instagram, solary/StreetCLIP-finetuned-InstaCities
# Example multi-model: VISION_PYTORCH_MODELS=geolocal/StreetCLIP,solary/StreetCLIP-finetuned-Instagram
VISION_PYTORCH_MODELS=geolocal/StreetCLIP
VISION_FUSION_STRATEGY=max_confidence
# Optional comma weights aligned with VISION_PYTORCH_MODELS (empty = equal). Used mainly with mean_probability.
VISION_MODEL_WEIGHTS=
# Forests, villages, farmland, wilderness prompts merged into the CLIP softmax grid (good for rural scenes).
USE_RURAL_NATURE_LABELS=True
# Neighbourhood / district names worldwide (Americas, Europe, Asia, …) — improves softmax beyond core city list.
USE_WORLD_DISTRICT_LABELS=True
# Seas, lakes, rivers, major mountain ranges (coarse reference points on the softmax grid).
USE_TERRAIN_WATER_LABELS=True
# Global biomes & scene types: deserts, savannas, wetlands, reefs, glaciers, farms, canyons, etc. (adds many CLIP labels).
USE_EXTENDED_LANDSCAPE_LABELS=True
# Extra CLIP pass: plant/vegetation prompts → coarse native-region hints (not species-level taxonomy).
USE_PLANT_GEO_HINTS=True
# Extra CLIP pass: scene-element tags (sky, water, urban, …) listed next to the map pin.
USE_IDENTIFIED_ELEMENTS=True
# Grouped architecture CLIP cues (silhouette, palette, density, luxury-vs-modest visual cues).
USE_ARCHITECTURE_HINTS=True
# Season / month stereotypes (CLIP sky/sun/foliage prompts) + upper-band RGB stats — not ephemeris.
USE_SEASON_MONTH_HINTS=True
# Flowers/shrubs + road surface CLIP hint groups (extra softmax).
USE_FLOWER_BUSH_ROAD_HINTS=True
# Multi–macro-region visual stereotypes (utilities, terrain, settlement patterns, façades worldwide) — one combined CLIP softmax pass; does not move the pin.
USE_GLOBE_REGIONAL_HINTS=True
# Fuse scene + architecture + season + flower-road + plant CLIP softmax into one image-text forward (faster CPU/GPU).
USE_BATCHED_CLIP_HINTS=True
# Rule-based “integrated estimate” narrative from all panels (no extra ML).
USE_INTEGRATED_ESTIMATE=True
# GeoCLIP (pip package geoclip): neural GPS regression fused with StreetCLIP place labels when nearby.
USE_GEOCLIP=True
GEOCLIP_LABEL_MATCH_MAX_KM=1500
# Probability-weighted blend of GeoCLIP top-K GPS outputs (reduces fragile rank-1 outliers). Use 1 for rank-1 only.
GEOCLIP_BLEND_TOP_K=3
# GeoCLIP hypotheses requested & returned when include_geoclip_rank_list=true (probability order).
GEOCLIP_INFERENCE_TOP_K=15
# Ask GeoCLIP for up to this many hypotheses per call (retries smaller k if the library errors).
GEOCLIP_PREDICT_TOPK_TRY_MAX=48
# Blend GeoCLIP ranks on the sphere (recommended). False = naive latitude/longitude average.
GEOCLIP_BLEND_USE_SPHERE_MEAN=True
# Second GeoCLIP pass on inner crop → merge distant pins (extra latency; richer than k alone).
GEOCLIP_MULTISCALE_ENABLED=False
GEOCLIP_MULTISCALE_CROP_MARGIN=0.08
GEOCLIP_MULTISCALE_MERGE_MIN_KM=85
GEOCLIP_MULTISCALE_MAX_HYPOTHESES=36
# If GeoCLIP rank 1 + StreetCLIP top-1 agree on a big city but another GeoCLIP rank fits a same-country runner-up centroid better (e.g. Kyiv vs Zhytomyr), nudge the pin to that rank.
HYBRID_STREETCLIP_ALT_GEOCLIP_RECONCILE=True
HYBRID_ALT_GEOCLIP_SCAN_TOP=8
HYBRID_ALT_GEOCLIP_MIN_IMPROVEMENT_KM=35
HYBRID_ALT_GEOCLIP_MIN_RANK_SEP_KM=28
HYBRID_ALT_GEOCLIP_MIN_SOFTMAX_ALT_CONF=0.035
HYBRID_ALT_GEOCLIP_MIN_GEOCLIP_RANK_CONF=0.006
# Real testing: leave these false (default). No fake pins unless you explicitly opt in:
USE_FILENAME_HINTS=False
ALLOW_LEGACY_MOCK_ENSEMBLE=False

# Feature Extraction Settings
ENABLE_LANDMARK_DETECTION=True
ENABLE_VEGETATION_ANALYSIS=True
ENABLE_ARCHITECTURE_ANALYSIS=True
ENABLE_TEXT_OCR=True

# Inference Settings
CONFIDENCE_THRESHOLD=0.3
# Raising this (e.g. 8) returns more StreetCLIP alternatives so hybrid reconcile can find regional cities (Zhytomyr vs Kyiv).
TOP_K_PREDICTIONS=8

# Wikipedia + OpenTopo cross-check (`include_external_validation` on /predict): optional CLIP vs English Wikipedia lead for each candidate before accepting the pin.
WIKIPEDIA_SEMANTIC_GATE_ENABLED=True
WIKIPEDIA_SEMANTIC_MIN_SIMILARITY=0.14
# Nearest N geosearch articles per candidate: CLIP image–text score each lead, best score vs threshold.
WIKIPEDIA_SEMANTIC_EVAL_TOP_TITLES=5

# OpenStreetMap Nominatim — names the city/town/village at the predicted pin (worldwide).
# NOMINATIM_HTTP_USER_AGENT is also used as User-Agent for Wikimedia (geosearch), NASA GIBS tiles, etc.
# Use a real app name + contact (URL or email). See Wikimedia API etiquette — generic bots get 403.
REVERSE_GEOCODE_ENABLED=True
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_HTTP_USER_AGENT=PhotoGeoLocal/1.0 (https://github.com/you/project; your.email@example.com)
REVERSE_GEOCODE_MAX_ALTERNATIVES=0
REVERSE_GEOCODE_INTER_REQUEST_DELAY_S=1.1
REVERSE_GEOCODE_RETRY_ATTEMPTS=2
REVERSE_GEOCODE_RETRY_BACKOFF_S=0.75
REVERSE_GEOCODE_DEFAULT_ACCEPT_LANGUAGE=en

# Database
DATABASE_URL=sqlite:///./geolocations.db

# APIs (Optional) — enables reference imagery after /predict (proxied images, key stays on server).
# In Google Cloud: enable "Maps Static API" and "Street View Static API" for this key.
GOOGLE_MAPS_API_KEY=
# Optional: rerank vision geo candidates by CLIP similarity to Street View panoramas (extra Street View API calls).
USE_STREETVIEW_REFINEMENT=False
STREETVIEW_REFINEMENT_MIN_SIMILARITY=0.28
STREETVIEW_REFINEMENT_MAX_CANDIDATES=5
# Comma headings in degrees (empty = single default view). More headings = more API calls per candidate.
STREETVIEW_REFINEMENT_HEADINGS=0,90,180,270
# Parallel HTTP fetches for those headings (per candidate). Set false if you hit API rate limits.
PARALLEL_STREETVIEW_HEADING_FETCHES=True
# Put vision alternatives closest to the top plant-native hint first (helps Street View candidate order).
REORDER_ALTERNATIVES_BY_PLANT_PROXIMITY=True
# If GeoCLIP lands near another grid centroid, adopt that row's place name (fixes hybrid label mismatch).
SNAP_PRIMARY_LABELS_TO_NEAREST_CENTROID=True
SNAP_PRIMARY_CENTROID_MAX_KM=95
SNAP_PRIMARY_CENTROID_MIN_ALT_CONFIDENCE=0.06
# Swap primary with an alternative closer to confident plant-region hints when geography conflicts.
PLANT_PRIMARY_RECONCILE_ENABLED=True
PLANT_PRIMARY_RECONCILE_MIN_HINT_CONFIDENCE=0.40
PLANT_PRIMARY_RECONCILE_MIN_PRIMARY_DISTANCE_KM=260
PLANT_PRIMARY_RECONCILE_MIN_GAIN_KM=90
# Evidence-weighted label pick: GeoCLIP pin fit + plant kernels + scene/biome + softmax (disables snap/reconcile/reorder when on).
USE_MULTI_CUE_REFINEMENT=True
MULTI_CUE_WEIGHT_GEO_PIN=0.40
MULTI_CUE_WEIGHT_PLANT=0.28
MULTI_CUE_WEIGHT_BIOME=0.18
MULTI_CUE_WEIGHT_SOFTMAX=0.14
MULTI_CUE_GEO_PIN_SCALE_KM=185
MULTI_CUE_PLANT_KERNEL_SIGMA_KM=700
MULTI_CUE_MIN_PROMOTION_MARGIN=0.042
# Multi-cue label promotion: refuse to swap place-name rows if centroid exceeds this km from fused pin (0 = off).
MULTI_CUE_MAX_LABEL_CENTROID_KM=0
# OpenTopoData public DEM (SRTM-class): local relief around the pin + demote Ocean/Sea softmax rows over dry land (no Google key).
USE_TERRAIN_ELEVATION_GATE=True
TERRAIN_ELEVATION_DATASET=srtm90m
OPENTOPODATA_BASE_URL=https://api.opentopodata.org/v1
OPENTOPODATA_TIMEOUT_S=12
OPENTOPODATA_BATCH_SIZE=80
TERRAIN_OCEAN_MAX_ELEVATION_M=120
TERRAIN_MOUNTAIN_MIN_ELEVATION_M=250
# If true, demote “Mountains” rows when DEM is below TERRAIN_MOUNTAIN_MIN_ELEVATION_M (noisier — off by default).
TERRAIN_DEMOTE_MOUNTAINS_LOW=False
TERRAIN_RELIEF_CROSS_ARC_DEG=0.018
# If true, swap primary away from Ocean/Sea when DEM is implausibly inland (experimental).
TERRAIN_SWAP_PRIMARY_OCEAN_MISMATCH=False
# When GeoCLIP’s blended GPS sits on flat open water (DEM) but StreetCLIP names land far away, snap to softmax coords.
SNAP_GEOCLIP_OFF_FLAT_WATER=True
SNAP_WATER_PIN_MIN_VS_SOFTMAX_KM=90
FLAT_WATER_SNAP_MAX_RELIEF_M=3.5
FLAT_WATER_SNAP_MAX_ABS_MEDIAN_M=15
FLAT_WATER_SNAP_CROSS_ARC_DEG=0.022
# English Wikipedia geosearch + lead extracts near the predicted pin (public API; scene-cue ranking).
USE_WIKIPEDIA_PLACE_CONTEXT=True
WIKIPEDIA_GEOSEARCH_RADIUS_M=2800
WIKIPEDIA_GEOSEARCH_LIMIT=18
WIKIPEDIA_TOP_ARTICLES_DISPLAY=8
# When scene cues align with a nearby Wikipedia POI, blend primary GPS toward that article (skipped for EXIF pins).
WIKIPEDIA_REFINEMENT_PRIMARY_PIN=True
WIKIPEDIA_REFINEMENT_MIN_RELEVANCE=7.5
WIKIPEDIA_REFINEMENT_MAX_ARTICLE_DISTANCE_M=1400
WIKIPEDIA_REFINEMENT_MIN_OVERLAP_CUES=2
WIKIPEDIA_REFINEMENT_BLEND_WEIGHT=0.42
# Large range/massif articles only: weak blend toward encyclopedia centroid when pin–centroid distance is between MAX_ARTICLE and this cap (m). 0 = disable regional pass.
WIKIPEDIA_REFINEMENT_REGIONAL_MAX_DISTANCE_M=420000
WIKIPEDIA_REFINEMENT_REGIONAL_BLEND_WEIGHT=0.14
# Sparse scenes (forest/mountains/village): widen geosearch + thematic title search when cue scores stay low.
WIKIPEDIA_SECONDARY_GEOSEARCH_FACTOR=1.62
WIKIPEDIA_WEAK_MATCH_MAX_SCORE=8.25
WIKIPEDIA_ENABLE_THEMATIC_SEARCH=True
WIKIPEDIA_MAX_THEMATIC_QUERIES=2
WIKIPEDIA_THEMATIC_SEARCH_LIMIT=6
WIKIPEDIA_COMPARE_ALTERNATIVE_PINS=True
WIKIPEDIA_ALT_PIN_FIT_MARGIN=4.25
WIKIPEDIA_ALT_PIN_FIT_MAX_GEO_KM=820
# Dangerous / rarely needed: promote primary to an alternative when Wikipedia overlap is vastly better (false default).
WIKIPEDIA_SHIFT_PRIMARY_ON_ALT_WIKI_FIT=False
# GeoCLIP hypotheses inside Finland/Sweden bbox (from plant cues) vs distant softmax centroid — spherical blend.
USE_GEOCLIP_CLUSTER_CONSENSUS=True
GEOCLIP_CLUSTER_CONSIDER_TOP=22
GEOCLIP_CLUSTER_MIN_HYPOTHESES=3
GEOCLIP_CLUSTER_MAX_SPREAD_KM=520
GEOCLIP_CLUSTER_MIN_DISPLACEMENT_KM=85
GEOCLIP_CLUSTER_MIN_WEIGHT_MASS=0.028
GEOCLIP_CLUSTER_PLANT_RADIUS_KM=950

# Local Ollama LLM detective (optional; requires `ollama serve` + `ollama pull qwen2.5:7b`)
USE_LLM_DETECTIVE=True
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_WARMUP_AT_STARTUP=True
# CPU 7B cold load can take 30–90s; keep HTTP timeout ≥ pipeline timeout.
OLLAMA_HTTP_TIMEOUT_SECONDS=300
LLM_DETECTIVE_TIMEOUT_SECONDS=300
