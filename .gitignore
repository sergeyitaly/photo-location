backend/app/data/generated/*.json
!backend/app/data/generated/.gitignore

# OS / IDE (optional local tooling)
.DS_Store
.idea/
.vscode/
.cursor/
.claude/
.kiro/

# Model / HF cache (if stored locally — not backend/app/models Python package)
.cache/
/models/
*.pt
*.bin
*.safetensors

# Logs
*.log
